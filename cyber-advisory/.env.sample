# ─────────────────────────────────────────────────────────────────────────
# Cyber Advisory Hub — single-tenant deployment config
# Copy to cyber-advisory.env, fill in the values, pass with: docker run --env-file
# Placeholders only — generate real secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──
HOST=0.0.0.0
PORT=8080

# ── Database (REQUIRED) — the only hard external dependency ──
MONGODB_DATABASE=advisory
#
# Pick ONE of the three ways to connect:
#
# (A) Full connection string — works for self-hosted or Atlas. Highest priority.
#     An EMPTY value is ignored (won't break the fallbacks below).
# MONGODB_URI=mongodb://user:pass@mongo:27017/advisory?authSource=admin
# MONGODB_URI=mongodb+srv://user:pass@cluster0.ab12c.mongodb.net/?retryWrites=true&w=majority
#
# (B) MongoDB Atlas — set the toggle and the app composes the mongodb+srv://
#     string for you (no port; password is URL-encoded automatically).
#     MONGODB_HOST is the Atlas CLUSTER HOST, e.g. cluster0.ab12c.mongodb.net
# MONGODB_ATLAS=1
# MONGODB_HOST=cluster0.ab12c.mongodb.net
# MONGODB_USER=appuser
# MONGODB_PASSWORD=app-password           # raw — the app URL-encodes it
# MONGODB_OPTIONS=retryWrites=true&w=majority
#
# (C) Self-hosted host/port (local clusters) — leave MONGODB_URI UNSET (not blank).
MONGODB_HOST=mongo
MONGODB_PORT=27017

# ── AI (REQUIRED for advisor / gap-analysis / document features) ──
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_GAP_MODEL=claude-sonnet-4-6     # claude-opus-4-8 for deeper gap analysis

# ── Single-box mode (REQUIRED for a standalone deploy) ──
# true = no external Temporal cluster; background work runs in-process / is skipped.
SINGLE_SERVER_MODE=true

# ── Sessions (REQUIRED) — long random value, keep stable across restarts ──
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# ── Host routing (REQUIRED) — must match how the client reaches the app ──
# Tenant pages are served at <tenant>.<CLIENT_BASE_DOMAIN>; admin at ADMIN_HOSTNAME.
CLIENT_BASE_DOMAIN=advisory.example.com
ADMIN_HOSTNAME=admin.advisory.example.com
ADMIN_ALLOWED_EMAILS=admin@example.com         # CSV of admin logins

# ── Password auth (set if tenant users sign in with email+password) ──
# Long random pepper — set BEFORE creating users; never change it afterwards.
PASSWORD_PEPPER=replace-with-openssl-rand-hex-32

# ── Admin SSO via Microsoft Entra (OPTIONAL — omit to use email allowlist only) ──
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=https://admin.advisory.example.com/admin/callback

# ── Tenant SSO via Keycloak (OPTIONAL — only if tenants log in through Keycloak) ──
# KEYCLOAK_BASE_URL=https://auth.example.com
# KEYCLOAK_CLIENT_ID=cyber-advisory
# KEYCLOAK_CLIENT_SECRET=

# ── Temporal (ONLY if SINGLE_SERVER_MODE=false) ──
# TEMPORAL_HOST=temporal:7233
# TEMPORAL_TASK_QUEUE=advisor-panel
