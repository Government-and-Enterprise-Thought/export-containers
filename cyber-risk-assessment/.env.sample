# ─────────────────────────────────────────────────────────────────────────
# Cyber Risk Assessment — single-tenant deployment config
# Copy to cyber-risk-assessment.env, fill in the values, pass with: docker run --env-file
# Placeholders only — generate real secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──
HOST=0.0.0.0
PORT=8080

# ── Database (REQUIRED) — the only hard external dependency ──
MONGODB_DATABASE=cyber-risk-assessment
#
# ★ RECOMMENDED for enterprise single-tenant: a JSON connection blob.
#   The client's secret-sync delivers ONE secret key holding a JSON object
#   {protocol,username,password,hostname,connectionOptions,connectionString}.
#   Map that key to MONGODB_CONNECTION_JSON; the app uses its connectionString
#   AND reads the database name from it — so you can leave MONGODB_DATABASE
#   unset. This wins over the options below.
# MONGODB_CONNECTION_JSON={"connectionString":"mongodb+srv://user:pass@host/cyber-risk-assessment?retryWrites=true&w=majority", ...}
#
# Otherwise pick ONE:
# (A) Full connection string (self-hosted or Atlas):
# MONGODB_URI=mongodb+srv://user:pass@cluster0.ab12c.mongodb.net/?retryWrites=true&w=majority
# (B) Atlas toggle (app composes mongodb+srv:// and URL-encodes the password):
# MONGODB_ATLAS=1
# MONGODB_HOST=cluster0.ab12c.mongodb.net
# MONGODB_USER=appuser
# MONGODB_PASSWORD=app-password
# MONGODB_OPTIONS=retryWrites=true&w=majority
# (C) Self-hosted host/port (leave MONGODB_URI UNSET):
# MONGODB_HOST=mongo
# MONGODB_PORT=27017

# ── Single-box mode (REQUIRED for a standalone deploy) ──
# true = no external Temporal cluster; background work runs in-process / is skipped.
SINGLE_SERVER_MODE=true

# ── Sessions (REQUIRED) — long random value, keep stable across restarts ──
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# ── Admin access (REQUIRED) ──
ADMIN_HOSTNAME=admin.cyber-risk-assessment.example.com
ADMIN_ALLOWED_EMAILS=admin@example.com          # CSV of admin logins

# ── Admin SSO via Microsoft Entra (the admin login method) ──
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://admin.cyber-risk-assessment.example.com/admin/callback
