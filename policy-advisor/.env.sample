# ─────────────────────────────────────────────────────────────────────────
# Policy Advisor (Cyber Policy) — single-tenant deployment config
# Copy to policy-advisor.env, fill in the values, pass with: docker run --env-file
# Placeholders only — generate real secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──
PORT=3000
COOKIE_SECURE=true              # set false ONLY if serving plain HTTP (no TLS)

# ── Database (REQUIRED) ──
# ★ RECOMMENDED for enterprise single-tenant: a JSON connection blob.
#   The client's secret-sync delivers ONE secret key holding a JSON object
#   {protocol,username,password,hostname,connectionOptions,connectionString}.
#   Map that key to MONGODB_CONNECTION_JSON; the app uses its connectionString
#   AND reads the database name from it — so you can leave MONGODB_DB unset.
#   This wins over MONGODB_URI / the Atlas toggle below.
# MONGODB_CONNECTION_JSON={"connectionString":"mongodb+srv://user:pass@host/v3_policy_hub?retryWrites=true&w=majority", ...}
#
# Otherwise: a full connection string (self-hosted or Atlas), or the Atlas toggle
# (MONGODB_ATLAS=1 + MONGODB_HOST/USER/PASSWORD). MONGODB_DB selects the database.
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=v3_policy_hub

# ── AI (REQUIRED for advisors / skill generation) ──
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Single-tenant mode (REQUIRED for a standalone client deploy) ──
# Pins every request to one workspace and replaces SSO with a token login:
# any browser carrying cookie `admin_token=<SINGLE_TENANT_ADMIN_TOKEN>` is an admin.
SINGLE_TENANT_DOMAIN=clientname
SINGLE_TENANT_ADMIN_TOKEN=replace-with-openssl-rand-hex-32
SINGLE_TENANT_ADMIN_EMAIL=admin@clientname.com

# ── Single-box mode (no external Temporal worker) ──
SINGLE_SERVER_MODE=true

# ── Routing (used for links/redirects; with SINGLE_TENANT_DOMAIN set, host
#    routing is bypassed, but set these to the client's real hostnames) ──
BASE_DOMAIN=cyberpolicy.example.com
ADMIN_DOMAIN=admin.cyberpolicy.example.com

# ── Password auth (set if tenant users sign in with email+password) ──
# Long random pepper — set BEFORE creating users; never change it afterwards.
PASSWORD_PEPPER=replace-with-openssl-rand-hex-32

# ── NOTE: seed the SCF reference data ──
# A fresh client DB is empty of the tenant-neutral SCF collections
# (scf_controls, scf_policies, scf_standards, scf_frameworks, scf_domains).
# After first login, load them once via Settings → Advanced → Seed & Backup
# (upload the supplied policy-advisor-seed.json). Idempotent; safe to re-run.
